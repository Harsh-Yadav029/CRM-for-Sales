						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.environment.set(\"authToken\", jsonData.token);",
									"}",
									"if (jsonData.tenantId) {",
									"    pm.environment.set(\"tenantId\", jsonData.tenantId);",
									"}"
